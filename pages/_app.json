:root{
  --bg:#0b1220;
  --panel:#121a2b;
  --panel2:#18233a;
  --text:#e7eefc;
  --muted:#8ea3c9;
  --good:#28c76f;
  --line:#24324d;
  --chip:#20304d;
}
*{box-sizing:border-box}
body{
  margin:0;
  font-family:Inter,Arial,sans-serif;
  background:linear-gradient(180deg,#08101e,#0b1220 35%,#08101e);
  color:var(--text);
}
button{cursor:pointer}
.topbar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  padding:18px 24px;
  border-bottom:1px solid var(--line);
  background:rgba(8,16,30,.82);
  backdrop-filter:blur(8px);
  position:sticky;
  top:0;
  z-index:5;
}
.topbar h1{font-size:18px;margin:0}
.topbar p{color:var(--muted);font-size:12px;margin:4px 0 0}
.actions{display:flex;gap:8px;flex-wrap:wrap}
.actions button{
  background:#183153;
  color:#d6e6ff;
  border:1px solid #28436b;
  border-radius:10px;
  padding:8px 10px;
  font-size:12px;
}
.container{padding:20px;display:grid;gap:16px}
.kpis{
  display:grid;
  grid-template-columns:repeat(5,minmax(0,1fr));
  gap:12px;
}
.grid{display:grid;gap:16px}
.two-col{grid-template-columns:1.6fr 1fr}
.card,.panel{
  background:linear-gradient(180deg,var(--panel),var(--panel2));
  border:1px solid var(--line);
  border-radius:16px;
  box-shadow:0 10px 30px rgba(0,0,0,.2);
}
.card{padding:16px}
.label{color:var(--muted);font-size:12px}
.value{font-size:28px;font-weight:700;margin-top:8px}
.meta{font-size:12px;color:var(--muted);margin-top:4px}
.good{color:var(--good)}
.panel{padding:16px}
.panel h2{margin:0 0 12px;font-size:15px}
.muted{color:var(--muted)}
.camera-grid{
  display:grid;
  grid-template-columns:repeat(2,minmax(0,1fr));
  gap:12px;
}
.cam{
  min-height:170px;
  border-radius:14px;
  background:#0b1322;
  border:1px solid #22314d;
  padding:12px;
  position:relative;
  overflow:hidden;
}
.cam::before{
  content:'';
  position:absolute;
  inset:0;
  background:
    radial-gradient(circle at 30% 20%, rgba(58,160,255,.18), transparent 45%),
    radial-gradient(circle at 75% 30%, rgba(40,199,111,.12), transparent 40%);
}
.camTop,.camBottom{
  display:flex;
  justify-content:space-between;
  position:relative;
}
.status{
  font-size:11px;
  padding:4px 8px;
  border-radius:999px;
  background:var(--chip);
}
.online{color:var(--good)}
.offline{color:#ff5c75}
.feed{
  height:92px;
  border-radius:10px;
  margin-top:10px;
  border:1px dashed #33486d;
  display:flex;
  align-items:center;
  justify-content:center;
  color:var(--muted);
  position:relative;
}
.camBottom{
  margin-top:10px;
  font-size:12px;
}
.badge{
  padding:5px 9px;
  border-radius:999px;
  font-size:11px;
  background:rgba(58,160,255,.15);
  color:#8ec8ff;
  border:1px solid rgba(58,160,255,.25);
}
.events{display:grid;gap:10px}
.event{
  display:grid;
  grid-template-columns:86px 1fr auto;
  gap:10px;
  align-items:center;
  padding:12px;
  border-radius:12px;
  background:#0e1627;
  border:1px solid #22314d;
}
.thumb{
  height:58px;
  border-radius:10px;
  background:linear-gradient(135deg,#20304d,#122033);
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:12px;
  color:var(--muted);
}
.event h3{font-size:13px;margin:0 0 4px}
.event p{margin:0;font-size:12px;color:var(--muted)}
.sev{
  padding:5px 10px;
  border-radius:999px;
  font-size:11px;
  font-weight:700;
}
.sev.critical{background:rgba(255,92,117,.15);color:#ff8a9b}
.sev.high{background:rgba(255,176,32,.15);color:#ffd17a}
.sev.medium{background:rgba(58,160,255,.15);color:#8ec8ff}
.table{
  width:100%;
  border-collapse:collapse;
  overflow:hidden;
  border-radius:12px;
}
.table th,.table td{
  padding:11px 10px;
  border-bottom:1px solid #213049;
  font-size:12px;
  text-align:left;
}
.table th{
  color:#c9d7f2;
  font-weight:600;
  background:#0e1627;
}
.table td{color:var(--muted)}
@media (max-width:1100px){
  .kpis{grid-template-columns:repeat(2,1fr)}
  .two-col{grid-template-columns:1fr}
  .camera-grid{grid-template-columns:1fr}
}
